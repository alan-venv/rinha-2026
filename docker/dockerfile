FROM rust:1.94-trixie AS build
WORKDIR /app
ENV RUSTFLAGS="-C target-feature=+avx2"
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
RUN mkdir src && echo "fn main(){}" > src/main.rs
RUN cargo fetch
COPY src ./src
RUN cargo build --release --bin rinha --bin lb

FROM gcr.io/distroless/cc-debian13
WORKDIR /app
COPY resources/*.bin ./resources/
COPY --from=build /app/target/release/rinha .
COPY --from=build /app/target/release/lb .
CMD [ "./rinha" ]
